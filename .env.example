# PostgreSQL
POSTGRES_USER=admin
POSTGRES_PASSWORD=changeme
POSTGRES_DB=tech_test_db
DATABASE_URL=postgresql://admin:changeme@localhost:5432/tech_test_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=your_super_secret_key_here
JWT_EXPIRES_IN=8h

# MQTT
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USERNAME=backend
MQTT_PASSWORD=changeme

# App
PORT=3000
NODE_ENV=development

# CORS (opcional — deixe vazio para permitir todas as origens em dev)
# CORS_ORIGIN=http://localhost:3000,chrome-extension://your-extension-id

# Screenshot storage (opcional — padrão: ./screenshots)
# SCREENSHOT_STORAGE_DIR=./screenshots
